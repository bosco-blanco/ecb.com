      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Generador de Firmas — Grupo En Copa de Balón</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600&family=DM+Sans:wght@300;400;500&display=swap\" rel=\"stylesheet\">\n  <style>\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n    :root {\n      --verde: #3a5a3e;\n      --verde-oscuro: #2a3f2d;\n      --crema: #f8f4ee;\n      --gris: #6b6b6b;\n      --gris-claro: #e8e4de;\n      --acento: #b5872a;\n    }\n\n    body {\n      font-family: 'DM Sans', sans-serif;\n      background: var(--crema);\n      min-height: 100vh;\n      display: flex;\n      flex-direction: column;\n      align-items: center;\n      padding: 48px 24px;\n    }\n\n    header {\n      text-align: center;\n      margin-bottom: 48px;\n    }\n\n    header .grupo-label {\n      font-size: 11px;\n      letter-spacing: 3px;\n      text-transform: uppercase;\n      color: var(--acento);\n      font-weight: 500;\n      margin-bottom: 8px;\n    }\n\n    header h1 {\n      font-family: 'Playfair Display', serif;\n      font-size: 28px;\n      color: var(--verde-oscuro);\n      font-weight: 600;\n    }\n\n    header p {\n      font-size: 13px;\n      color: var(--gris);\n      margin-top: 6px;\n    }\n\n    .container {\n      width: 100%;\n      max-width: 860px;\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 32px;\n      align-items: start;\n    }\n\n    @media (max-width: 680px) {\n      .container { grid-template-columns: 1fr; }\n    }\n\n    /* FORM */\n    .form-card {\n      background: white;\n      border-radius: 16px;\n      padding: 32px;\n      box-shadow: 0 2px 24px rgba(42,63,45,0.07);\n    }\n\n    .form-card h2 {\n      font-family: 'Playfair Display', serif;\n      font-size: 18px;\n      color: var(--verde-oscuro);\n      margin-bottom: 24px;\n    }\n\n    .field {\n      margin-bottom: 18px;\n    }\n\n    label {\n      display: block;\n      font-size: 11px;\n      letter-spacing: 1.5px;\n      text-transform: uppercase;\n      color: var(--gris);\n      font-weight: 500;\n      margin-bottom: 6px;\n    }\n\n    input, select {\n      width: 100%;\n      border: 1.5px solid var(--gris-claro);\n      border-radius: 8px;\n      padding: 10px 14px;\n      font-family: 'DM Sans', sans-serif;\n      font-size: 14px;\n      color: var(--verde-oscuro);\n      background: white;\n      outline: none;\n      transition: border-color 0.2s;\n    }\n\n    input:focus, select:focus {\n      border-color: var(--verde);\n    }\n\n    .btn-generate {\n      width: 100%;\n      margin-top: 8px;\n      background: var(--verde);\n      color: white;\n      border: none;\n      border-radius: 8px;\n      padding: 13px;\n      font-family: 'DM Sans', sans-serif;\n      font-size: 14px;\n      font-weight: 500;\n      letter-spacing: 0.5px;\n      cursor: pointer;\n      transition: background 0.2s;\n    }\n\n    .btn-generate:hover { background: var(--verde-oscuro); }\n\n    /* PREVIEW */\n    .preview-card {\n      background: white;\n      border-radius: 16px;\n      padding: 32px;\n      box-shadow: 0 2px 24px rgba(42,63,45,0.07);\n    }\n\n    .preview-card h2 {\n      font-family: 'Playfair Display', serif;\n      font-size: 18px;\n      color: var(--verde-oscuro);\n      margin-bottom: 24px;\n    }\n\n    #signature-preview {\n      border: 1.5px dashed var(--gris-claro);\n      border-radius: 10px;\n      padding: 20px;\n      min-height: 160px;\n      background: #fdfcfa;\n    }\n\n    /* COPY SECTION */\n    .copy-section {\n      width: 100%;\n      max-width: 860px;\n      margin-top: 24px;\n      background: white;\n      border-radius: 16px;\n      padding: 28px 32px;\n      box-shadow: 0 2px 24px rgba(42,63,45,0.07);\n    }\n\n    .copy-section h2 {\n      font-family: 'Playfair Display', serif;\n      font-size: 18px;\n      color: var(--verde-oscuro);\n      margin-bottom: 6px;\n    }\n\n    .copy-section p {\n      font-size: 13px;\n      color: var(--gris);\n      margin-bottom: 16px;\n    }\n\n    .code-area {\n      background: #f4f0ea;\n      border-radius: 8px;\n      padding: 14px 16px;\n      font-size: 11px;\n      font-family: monospace;\n      color: #444;\n      white-space: pre-wrap;\n      word-break: break-all;\n      max-height: 180px;\n      overflow-y: auto;\n      margin-bottom: 14px;\n    }\n\n    .btn-copy {\n      background: var(--acento);\n      color: white;\n      border: none;\n      border-radius: 8px;\n      padding: 11px 22px;\n      font-family: 'DM Sans', sans-serif;\n      font-size: 13px;\n      font-weight: 500;\n      cursor: pointer;\n      transition: opacity 0.2s;\n    }\n\n    .btn-copy:hover { opacity: 0.88; }\n\n    .instructions {\n      width: 100%;\n      max-width: 860px;\n      margin-top: 24px;\n      background: var(--verde-oscuro);\n      color: white;\n      border-radius: 16px;\n      padding: 28px 32px;\n    }\n\n    .instructions h3 {\n      font-family: 'Playfair Display', serif;\n      font-size: 16px;\n      margin-bottom: 14px;\n      color: #d4c9a8;\n    }\n\n    .instructions ol {\n      padding-left: 18px;\n      font-size: 13px;\n      line-height: 2;\n      color: #ccc;\n    }\n\n    .instructions ol li strong { color: white; }\n\n    /* ACTUAL SIGNATURE STYLES (inline for copy) */\n  </style>\n</head>\n<body>\n\n  <header>\n    <div class=\"grupo-label\">Herramienta interna</div>\n    <h1>Generador de Firmas</h1>\n    <p>Grupo En Copa de Balón · Crea tu firma profesional para Gmail</p>\n  </header>\n\n  <div class=\"container\">\n    <!-- FORMULARIO -->\n    <div class=\"form-card\">\n      <h2>Tus datos</h2>\n\n      <div class=\"field\">\n        <label>Nombre</label>\n        <input type=\"text\" id=\"f-nombre\" placeholder=\"Ej: Bosco\" oninput=\"updatePreview()\">\n      </div>\n      <div class=\"field\">\n        <label>Apellidos</label>\n        <input type=\"text\" id=\"f-apellidos\" placeholder=\"Ej: Blanco\" oninput=\"updatePreview()\">\n      </div>\n      <div class=\"field\">\n        <label>Cargo</label>\n        <input type=\"text\" id=\"f-cargo\" placeholder=\"Ej: Business Development Manager\" oninput=\"updatePreview()\">\n      </div>\n      <div class=\"field\">\n        <label>Teléfono</label>\n        <input type=\"text\" id=\"f-telefono\" placeholder=\"Ej: +34 607 633 882\" oninput=\"updatePreview()\">\n      </div>\n      <div class=\"field\">\n        <label>Email</label>\n        <input type=\"email\" id=\"f-email\" placeholder=\"Ej: bosco@encopadebalon.com\" oninput=\"updatePreview()\">\n      </div>\n      <div class=\"field\">\n        <label>Marca principal</label>\n        <select id=\"f-marca\" onchange=\"updatePreview()\">\n          <option value=\"ecb\">En Copa de Balón</option>\n          <option value=\"margaritas\">Las Margaritas</option>\n          <option value=\"brassafira\">Brassafira</option>\n          <option value=\"panthera\">Panthera</option>\n          <option value=\"ancestors\">Ancestors</option>\n          <option value=\"rubicon\">Rubicon</option>\n        </select>\n      </div>\n\n      <button class=\"btn-generate\" onclick=\"updatePreview()\">Actualizar firma</button>\n    </div>\n\n    <!-- PREVIEW -->\n    <div class=\"preview-card\">\n      <h2>Vista previa</h2>\n      <div id=\"signature-preview\">\n        <p style=\"color:#aaa;font-size:13px;text-align:center;padding-top:40px;\">Rellena el formulario para ver tu firma →</p>\n      </div>\n    </div>\n  </div>\n\n  <!-- COPY HTML -->\n  <div class=\"copy-section\">\n    <h2>Código HTML para copiar</h2>\n    <p>Copia este código y pégalo directamente en Gmail → Ajustes → Firma</p>\n    <div class=\"code-area\" id=\"html-output\">Aquí aparecerá el HTML de tu firma...</div>\n    <button class=\"btn-copy\" onclick=\"copyHTML()\">📋 Copiar HTML</button>\n    <span id=\"copy-feedback\" style=\"margin-left:12px;font-size:12px;color:var(--verde);opacity:0;transition:opacity 0.3s;\">¡Copiado!</span>\n  </div>\n\n  <!-- INSTRUCCIONES -->\n  <div class=\"instructions\">\n    <h3>Cómo instalar tu firma en Gmail</h3>\n    <ol>\n      <li>Copia el HTML de arriba</li>\n      <li>Abre <strong>Gmail → ⚙️ Ajustes → Ver todos los ajustes</strong></li>\n      <li>Baja hasta la sección <strong>Firma</strong> y haz clic en \"Crear nueva\"</li>\n      <li>En la barra de herramientas del editor, haz clic en <strong>&lt;&gt; (insertar HTML)</strong></li>\n      <li>Pega el código y guarda los cambios</li>\n    </ol>\n  </div>\n\n  <script>\n    const brandColors = {\n      ecb:         { color: '#3a5a3e', label: 'Grupo En Copa de Balón' },\n      margaritas:  { color: '#3a5a3e', label: 'Las Margaritas' },\n      brassafira:  { color: '#1a1a1a', label: 'Brassafira' },\n      panthera:    { color: '#4a3000', label: 'Panthera' },\n      ancestors:   { color: '#2d2d2d', label: 'Ancestors' },\n      rubicon:     { color: '#c0392b', label: 'Rubicon' },\n    };\n\n    function buildSignatureHTML(nombre, apellidos, cargo, telefono, email, marca) {\n      const b = brandColors[marca] || brandColors.ecb;\n      const fullName = [nombre, apellidos].filter(Boolean).join(' ') || 'Tu Nombre';\n      const cargoText = cargo || 'Tu Cargo';\n      const telText = telefono || '';\n      const emailText = email || '';\n\n      // Logos in SVG text (hosted on a reliable CDN or inline)\n      // For now using text representation — replace img src with your actual hosted logos\n      return `<table cellpadding=\"0\" cellspacing=\"0\" border=\"0\" style=\"font-family:Georgia,serif;max-width:520px;\">\n  <tr>\n    <td style=\"padding:0 0 14px 0;border-bottom:2px solid ${b.color};\">\n      <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n        <tr>\n          <td style=\"padding-right:18px;vertical-align:middle;\">\n            <!-- LOGO PLACEHOLDER: reemplaza el src con tu logo real en alta resolución -->\n            <img src=\"https://via.placeholder.com/80x40/3a5a3e/ffffff?text=ECB\" width=\"80\" height=\"40\" alt=\"En Copa de Balón\" style=\"display:block;\">\n          </td>\n          <td style=\"border-left:1px solid #ddd;padding-left:18px;vertical-align:middle;\">\n            <p style=\"margin:0;font-family:Georgia,serif;font-size:18px;font-weight:600;color:${b.color};line-height:1.2;\">${fullName}</p>\n            <p style=\"margin:4px 0 0 0;font-family:Arial,sans-serif;font-size:12px;color:#666;font-weight:400;letter-spacing:0.3px;\">${cargoText}</p>\n            <p style=\"margin:2px 0 0 0;font-family:Arial,sans-serif;font-size:11px;color:#888;font-style:italic;\">${b.label}</p>\n          </td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n  <tr>\n    <td style=\"padding:12px 0;\">\n      <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n        ${telText ? `<tr>\n          <td style=\"padding:2px 8px 2px 0;font-family:Arial,sans-serif;font-size:11px;color:#888;\">📞</td>\n          <td style=\"padding:2px 0;font-family:Arial,sans-serif;font-size:12px;color:#444;\"><a href=\"tel:${telText.replace(/\\s/g,'')}\" style=\"color:#444;text-decoration:none;\">${telText}</a></td>\n        </tr>` : ''}\n        ${emailText ? `<tr>\n          <td style=\"padding:2px 8px 2px 0;font-family:Arial,sans-serif;font-size:11px;color:#888;\">✉️</td>\n          <td style=\"padding:2px 0;font-family:Arial,sans-serif;font-size:12px;color:#444;\"><a href=\"mailto:${emailText}\" style=\"color:${b.color};text-decoration:none;\">${emailText}</a></td>\n        </tr>` : ''}\n        <tr>\n          <td style=\"padding:2px 8px 2px 0;font-family:Arial,sans-serif;font-size:11px;color:#888;\">🌐</td>\n          <td style=\"padding:2px 0;font-family:Arial,sans-serif;font-size:12px;\"><a href=\"https://www.encopadebalon.com\" style=\"color:${b.color};text-decoration:none;\">www.encopadebalon.com</a></td>\n        </tr>\n        <tr>\n          <td style=\"padding:2px 8px 2px 0;font-family:Arial,sans-serif;font-size:11px;color:#888;\">📸</td>\n          <td style=\"padding:2px 0;font-family:Arial,sans-serif;font-size:12px;\"><a href=\"https://instagram.com/encopadebalon_\" style=\"color:${b.color};text-decoration:none;\">@encopadebalon_</a></td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n  <tr>\n    <td style=\"padding-top:12px;border-top:1px solid #e8e4de;\">\n      <!-- LOGOS BARRA INFERIOR: sustituir por logos reales -->\n      <table cellpadding=\"0\" cellspacing=\"0\" border=\"0\">\n        <tr>\n          <td style=\"padding-right:14px;font-family:Georgia,serif;font-size:9px;color:#999;letter-spacing:1px;text-transform:uppercase;\">Las Margaritas</td>\n          <td style=\"padding-right:14px;font-family:Georgia,serif;font-size:9px;color:#999;letter-spacing:0.5px;\">en copa de balón</td>\n          <td style=\"padding-right:14px;font-family:Arial,sans-serif;font-size:9px;color:#999;letter-spacing:1px;\">BRASSAFIRA</td>\n          <td style=\"padding-right:14px;font-family:Arial,sans-serif;font-size:9px;color:#999;letter-spacing:1px;\">PANTHERA</td>\n          <td style=\"padding-right:14px;font-family:Arial,sans-serif;font-size:9px;color:#999;letter-spacing:1px;\">ANCESTORS</td>\n          <td style=\"font-family:Arial,sans-serif;font-size:9px;color:#999;letter-spacing:1px;\">RUBICON</td>\n        </tr>\n      </table>\n    </td>\n  </tr>\n</table>`;\n    }\n\n    function updatePreview() {\n      const nombre    = document.getElementById('f-nombre').value.trim();\n      const apellidos = document.getElementById('f-apellidos').value.trim();\n      const cargo     = document.getElementById('f-cargo').value.trim();\n      const telefono  = document.getElementById('f-telefono').value.trim();\n      const email     = document.getElementById('f-email').value.trim();\n      const marca     = document.getElementById('f-marca').value;\n\n      const html = buildSignatureHTML(nombre, apellidos, cargo, telefono, email, marca);\n\n      document.getElementById('signature-preview').innerHTML = html;\n      document.getElementById('html-output').textContent = html;\n    }\n\n    function copyHTML() {\n      const text = document.getElementById('html-output').textContent;\n      navigator.clipboard.writeText(text).then(() => {\n        const fb = document.getElementById('copy-feedback');\n        fb.style.opacity = '1';\n        setTimeout(() => { fb.style.opacity = '0'; }, 2200);\n      });\n    }\n  </script>\n</body>\n</html>",
