{% doc %}
  @prompt
    añadir un titulo para este liquid personalizado
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-custom-liquid-{{ ai_gen_id }} {
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    display: block;
  }

  .ai-custom-liquid-heading-{{ ai_gen_id }} {
    font-family: {{ block.settings.heading_font.family }}, {{ block.settings.heading_font.fallback_families }};
    font-weight: {{ block.settings.heading_font.weight }};
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 0 {{ block.settings.heading_spacing }}px 0;
  }

  .ai-custom-liquid-content-{{ ai_gen_id }} {
    width: 100%;
  }
{% endstyle %}

<custom-liquid-block-{{ ai_gen_id }} class="ai-custom-liquid-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading != blank %}
    <h2 class="ai-custom-liquid-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-custom-liquid-content-{{ ai_gen_id }}">
    {{ block.settings.liquid_code }}
  </div>
</custom-liquid-block-{{ ai_gen_id }}>

<script>
  (function() {
    class CustomLiquidBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }
    customElements.define('custom-liquid-block-{{ ai_gen_id }}', CustomLiquidBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Liquid personalizado",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Título"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Título",
      "default": "Contenido personalizado"
    },
    {
      "type": "font_picker",
      "id": "heading_font",
      "label": "Fuente del título",
      "default": "cormorant_n4"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 16,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Tamaño del título",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color del título",
      "default": "#000000"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alineación del título",
      "options": [
        {
          "value": "left",
          "label": "Izquierda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "right",
          "label": "Derecha"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Espaciado inferior del título",
      "default": 20
    },
    {
      "type": "header",
      "content": "Código Liquid"
    },
    {
      "type": "liquid",
      "id": "liquid_code",
      "label": "Código Liquid personalizado"
    },
    {
      "type": "header",
      "content": "Diseño"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Ancho en escritorio",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Liquid personalizado"
    }
  ]
}
{% endschema %}
