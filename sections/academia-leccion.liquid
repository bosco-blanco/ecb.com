{% comment %}
  Academia del Vino ECDB — Lección individual
  Sección: Página de lección con video, acordeón, vinos y quiz
  Requiere: {% render 'academia-tokens' %}
{% endcomment %}

{% render 'academia-tokens' %}

{% style %}
  /* ========== ACADEMIA LECCIÓN ========== */

  /* Breadcrumb */
  .acad-breadcrumb {
    max-width: 1360px; margin: 0 auto;
    padding: 22px 32px 8px;
    font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--acad-muted);
  }
  .acad-breadcrumb a { color: var(--acad-muted); transition: color .2s; }
  .acad-breadcrumb a:hover { color: var(--acad-bordeaux); }
  .acad-breadcrumb .acad-sep { color: var(--acad-gold); margin: 0 10px; }
  .acad-breadcrumb .acad-current { color: var(--acad-wine-brown); font-weight: 500; }

  /* Main layout */
  .acad-lesson-main {
    max-width: 1360px; margin: 0 auto;
    padding: 20px 32px 80px;
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: 48px;
  }

  /* Hero title */
  .acad-lesson-hero {
    padding-bottom: 28px;
    border-bottom: 1px solid var(--acad-line);
    margin-bottom: 32px;
  }
  .acad-lesson-hero .acad-kicker {
    display: inline-flex; align-items: center; gap: 10px;
    font-size: 11px; letter-spacing: 0.3em; text-transform: uppercase;
    color: var(--acad-bordeaux); font-weight: 600;
    margin-bottom: 14px;
  }
  .acad-lesson-hero .acad-kicker::before {
    content:''; width: 28px; height: 1px; background: var(--acad-gold);
  }
  .acad-lesson-hero h1 {
    font-family: var(--acad-serif);
    font-size: clamp(36px, 4.2vw, 54px);
    line-height: 1.02;
    letter-spacing: -0.01em;
    color: var(--acad-wine-brown);
    font-weight: 400;
  }
  .acad-lesson-hero h1 em { font-style: italic; color: var(--acad-bordeaux); }
  .acad-lesson-hero .acad-meta {
    margin-top: 18px;
    display: flex; flex-wrap: wrap; gap: 8px 20px;
    font-size: 12px; color: var(--acad-muted);
    letter-spacing: 0.1em; text-transform: uppercase;
  }
  .acad-lesson-hero .acad-meta span { display:inline-flex; align-items:center; gap:8px; }
  .acad-lesson-hero .acad-meta .acad-dot { width: 4px; height: 4px; border-radius:50%; background: var(--acad-gold); }
  .acad-lesson-hero .acad-meta .acad-author {
    display: inline-flex; align-items: center; gap: 10px;
    color: var(--acad-wine-brown); font-weight: 500;
  }
  .acad-mini-av {
    width: 24px; height: 24px; border-radius:50%;
    background: var(--acad-bordeaux); color: var(--acad-cream);
    display:grid; place-items:center;
    font-family: var(--acad-serif); font-size: 11px;
    letter-spacing: 0;
  }

  /* Video */
  .acad-video-wrap {
    position: relative;
    aspect-ratio: 16/9;
    background: var(--acad-wine-brown);
    overflow: hidden;
    margin-bottom: 32px;
  }
  .acad-video-wrap::before {
    content:''; position:absolute; inset:0;
    background:
      radial-gradient(circle at 50% 45%, rgba(122,31,61,0.55) 0%, transparent 60%),
      linear-gradient(135deg, #2C1810 0%, #7A1F3D 100%);
  }
  .acad-video-inner {
    position: absolute; inset: 0;
    display: flex; flex-direction: column; justify-content: space-between;
    padding: 28px;
    color: var(--acad-cream);
  }
  .acad-video-top { display: flex; justify-content: space-between; font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,252,241,0.8); }
  .acad-video-top .acad-lv { color: var(--acad-gold); }
  .acad-play-btn {
    position: absolute; top:50%; left:50%;
    transform: translate(-50%,-50%);
    width: 92px; height: 92px;
    border-radius: 50%;
    background: var(--acad-gold);
    display: grid; place-items: center;
    cursor: pointer;
    transition: all .25s ease;
    box-shadow: 0 0 0 0 rgba(212,185,116,0.6);
  }
  .acad-play-btn:hover {
    transform: translate(-50%,-50%) scale(1.08);
    box-shadow: 0 0 0 18px rgba(212,185,116,0.15);
  }
  .acad-play-btn::before {
    content:'';
    width: 0; height: 0;
    border-left: 24px solid var(--acad-wine-brown);
    border-top: 16px solid transparent;
    border-bottom: 16px solid transparent;
    margin-left: 6px;
  }
  .acad-video-bottom {
    display: flex; justify-content: space-between; align-items: end;
  }
  .acad-video-title-overlay {
    font-family: var(--acad-serif); font-style: italic;
    font-size: 24px; max-width: 60%; line-height: 1.2;
  }
  .acad-video-controls {
    display:flex; gap: 10px;
    font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase;
    opacity: 0.85;
  }
  .acad-video-controls span { padding: 6px 10px; border: 1px solid rgba(255,252,241,0.3); }

  /* Section eyebrows */
  .acad-section-eyebrow {
    display: flex; align-items: center; gap: 12px;
    margin: 48px 0 18px;
    font-size: 11px; letter-spacing: 0.28em; text-transform: uppercase;
    color: var(--acad-gold-deep); font-weight: 600;
  }
  .acad-section-eyebrow::before,
  .acad-section-eyebrow::after {
    content:''; height: 1px; background: var(--acad-line); flex: 1;
  }
  .acad-section-eyebrow.acad-left::before { display: none; }
  .acad-section-eyebrow.acad-left::after { flex: 1; }

  .acad-section-title {
    font-family: var(--acad-serif);
    font-size: 32px; margin-bottom: 18px;
    color: var(--acad-wine-brown); font-weight: 500;
  }
  .acad-section-title em { font-style: italic; color: var(--acad-bordeaux); }

  /* Prose */
  .acad-prose {
    font-size: 17px; line-height: 1.65;
    color: var(--acad-ink-soft);
    max-width: 68ch;
  }
  .acad-prose p { margin: 0 0 16px; }
  .acad-prose .acad-drop::first-letter {
    font-family: var(--acad-serif);
    font-size: 68px;
    float: left;
    line-height: 0.85;
    padding: 6px 12px 0 0;
    color: var(--acad-bordeaux);
    font-style: italic;
    font-weight: 500;
  }

  /* Accordion */
  .acad-accordion { margin-top: 24px; border-top: 1px solid var(--acad-line); }
  .acad-acc-item { border-bottom: 1px solid var(--acad-line); }
  .acad-acc-head {
    width: 100%; text-align: left;
    padding: 22px 0;
    display: flex; align-items: center; gap: 20px;
    font-family: var(--acad-serif);
    font-size: 22px;
    color: var(--acad-wine-brown);
    transition: color .2s;
  }
  .acad-acc-head:hover { color: var(--acad-bordeaux); }
  .acad-acc-num {
    font-family: var(--acad-sans); font-size: 11px;
    letter-spacing: 0.2em; color: var(--acad-gold-deep);
    font-weight: 600;
    width: 28px; flex-shrink: 0;
  }
  .acad-acc-title em { font-style: italic; }
  .acad-acc-plus {
    margin-left: auto; flex-shrink: 0;
    width: 20px; height: 20px; position: relative;
  }
  .acad-acc-plus::before, .acad-acc-plus::after {
    content:''; position:absolute; background: var(--acad-wine-brown);
    transition: transform .25s;
  }
  .acad-acc-plus::before { left:0; right:0; top:50%; height:1px; transform: translateY(-50%); }
  .acad-acc-plus::after { top:0; bottom:0; left:50%; width:1px; transform: translateX(-50%); }
  .acad-acc-item.acad-open .acad-acc-plus::after { transform: translateX(-50%) rotate(90deg); }
  .acad-acc-body {
    max-height: 0; overflow: hidden;
    transition: max-height .4s ease;
  }
  .acad-acc-item.acad-open .acad-acc-body { max-height: 800px; }
  .acad-acc-body-inner {
    padding: 4px 0 28px 48px;
    font-size: 16px; line-height: 1.65;
    color: var(--acad-ink-soft);
    max-width: 68ch;
  }
  .acad-acc-body-inner .acad-pull {
    border-left: 2px solid var(--acad-gold);
    padding: 6px 0 6px 18px;
    margin: 16px 0;
    font-family: var(--acad-serif);
    font-size: 19px; font-style: italic;
    color: var(--acad-wine-brown);
  }

  /* Wine cards */
  .acad-wine-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 20px; margin-top: 20px;
  }
  .acad-wine-card {
    background: var(--acad-cream);
    border: 1px solid var(--acad-line);
    display: flex; flex-direction: column;
    transition: all .25s ease;
    cursor: pointer;
    text-decoration: none;
    color: inherit;
  }
  .acad-wine-card:hover { border-color: var(--acad-gold-deep); transform: translateY(-2px); box-shadow: var(--acad-shadow-1); }
  .acad-wine-img {
    aspect-ratio: 4/5;
    background: var(--acad-cream-2);
    position: relative;
    display: grid; place-items: center;
    overflow: hidden;
    border-bottom: 1px solid var(--acad-line);
  }
  .acad-wine-img svg { width: 60%; height: 90%; }
  .acad-wine-img .acad-vintage-stamp {
    position: absolute; top: 14px; right: 14px;
    font-family: var(--acad-serif); font-style: italic;
    font-size: 13px; color: var(--acad-bordeaux);
    padding: 4px 10px;
    background: var(--acad-cream);
    border: 1px solid var(--acad-gold);
    letter-spacing: 0.08em;
  }
  .acad-wine-info { padding: 18px 20px 22px; }
  .acad-wine-bodega { font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase; color: var(--acad-muted); }
  .acad-wine-name {
    font-family: var(--acad-serif); font-size: 22px;
    color: var(--acad-wine-brown);
    margin: 6px 0 10px;
    font-weight: 500;
  }
  .acad-wine-name em { font-style: italic; }
  .acad-wine-meta {
    font-size: 12px; color: var(--acad-ink-soft);
    padding-top: 12px; border-top: 1px dashed var(--acad-line);
    display: flex; justify-content: space-between;
    letter-spacing: 0.04em;
  }
  .acad-wine-meta .acad-do { color: var(--acad-bordeaux); font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; font-size: 11px; }

  /* Quiz CTA */
  .acad-quiz-cta {
    margin-top: 56px;
    background: var(--acad-wine-brown);
    padding: 44px 48px;
    display: flex; align-items: center; justify-content: space-between;
    gap: 32px;
    position: relative;
    overflow: hidden;
  }
  .acad-quiz-cta::before {
    content:''; position:absolute; right: -40px; top: -40px;
    width: 220px; height: 220px;
    background: radial-gradient(circle, rgba(212,185,116,0.2), transparent 70%);
  }
  .acad-quiz-cta .acad-kicker { font-size: 11px; letter-spacing: 0.28em; text-transform: uppercase; color: var(--acad-gold); margin-bottom: 8px; }
  .acad-quiz-cta h3 {
    font-family: var(--acad-serif);
    font-size: 32px; color: var(--acad-cream); max-width: 560px; line-height: 1.1; font-weight: 400;
  }
  .acad-quiz-cta h3 em { color: var(--acad-gold); font-style: italic; }
  .acad-quiz-cta p { margin-top: 10px; color: rgba(255,252,241,0.7); font-size: 14px; max-width: 520px; }
  .acad-quiz-btn {
    flex-shrink: 0;
    display: inline-flex; align-items: center; gap: 14px;
    padding: 20px 30px;
    background: var(--acad-gold); color: var(--acad-wine-brown);
    font-size: 13px; letter-spacing: 0.18em; text-transform: uppercase;
    font-weight: 700;
    transition: all .2s ease;
    border: 2px solid var(--acad-gold);
    text-decoration: none;
  }
  .acad-quiz-btn:hover { background: var(--acad-cream); border-color: var(--acad-cream); }
  .acad-quiz-btn .acad-arrow { width: 20px; height: 1px; background: var(--acad-wine-brown); position: relative; }
  .acad-quiz-btn .acad-arrow::after { content:''; position: absolute; right:0; top: -3px; width: 7px; height: 7px; border-top: 1px solid var(--acad-wine-brown); border-right: 1px solid var(--acad-wine-brown); transform: rotate(45deg); }

  /* Sidebar */
  .acad-lesson-aside {
    position: sticky; top: 100px; align-self: start;
  }
  .acad-side-box {
    background: var(--acad-cream);
    border: 1px solid var(--acad-line);
    padding: 24px;
  }
  .acad-side-box .eyebrow { margin-bottom: 10px; display:flex; align-items: center; gap: 10px; }
  .acad-side-box .eyebrow::before { content:''; width: 16px; height: 1px; background: var(--acad-gold); }
  .acad-side-box h3 {
    font-family: var(--acad-serif);
    font-size: 22px; color: var(--acad-wine-brown);
    line-height: 1.15; font-weight: 500;
  }
  .acad-side-box h3 em { font-style: italic; }
  .acad-side-box .acad-month-sub {
    font-size: 12px; color: var(--acad-bordeaux);
    letter-spacing: 0.14em; text-transform: uppercase;
    margin-top: 4px; font-weight: 600;
  }
  .acad-month-progress {
    margin: 18px 0 22px;
    display: flex; align-items: center; gap: 12px;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--acad-muted);
  }
  .acad-month-progress .acad-bar { flex:1; height: 4px; background: var(--acad-line-soft); position: relative; }
  .acad-month-progress .acad-bar i { position:absolute; left:0; top:0; bottom:0; background: var(--acad-gold); }

  /* Lesson index */
  .acad-lesson-index {
    list-style: none; padding: 0; margin: 0;
    border-top: 1px solid var(--acad-line);
  }
  .acad-lesson-index li {
    display: flex; align-items: flex-start; gap: 14px;
    padding: 14px 0;
    border-bottom: 1px solid var(--acad-line);
    font-size: 14px;
    cursor: pointer;
    transition: all .2s;
  }
  .acad-lesson-index li:hover { padding-left: 6px; }
  .acad-lesson-index li.acad-done .acad-num { background: var(--acad-gold); color: var(--acad-wine-brown); }
  .acad-lesson-index li.acad-current {
    background: var(--acad-cream-2); margin: 0 -24px; padding-left: 24px; padding-right: 24px;
    border-left: 2px solid var(--acad-bordeaux); margin-left: -26px; padding-left: 22px;
  }
  .acad-lesson-index li.acad-current .acad-num { background: var(--acad-wine-brown); color: var(--acad-gold); }
  .acad-lesson-index li.acad-locked { opacity: 0.5; cursor: not-allowed; }
  .acad-lesson-index li.acad-locked:hover { padding-left: 0; }
  .acad-lesson-index .acad-num {
    width: 26px; height: 26px; border-radius: 50%;
    background: var(--acad-cream-2); color: var(--acad-muted);
    display: grid; place-items: center;
    font-family: var(--acad-serif); font-size: 13px;
    flex-shrink: 0; font-weight: 500;
  }
  .acad-lesson-index .acad-text { flex: 1; }
  .acad-lesson-index .acad-li-title {
    font-family: var(--acad-serif); font-size: 17px;
    color: var(--acad-wine-brown); line-height: 1.1; font-weight: 500;
  }
  .acad-lesson-index .acad-li-title em { font-style: italic; }
  .acad-lesson-index .acad-dur {
    font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--acad-muted); margin-top: 4px;
  }

  /* Terroir stats */
  .acad-side-box.acad-terroir { margin-top: 20px; background: var(--acad-cream-2); }
  .acad-terroir-stat { display: flex; justify-content: space-between; padding: 10px 0; border-bottom: 1px solid var(--acad-line); font-size: 13px; }
  .acad-terroir-stat:last-child { border-bottom: 0; }
  .acad-terroir-stat b { font-family: var(--acad-serif); font-weight: 500; color: var(--acad-wine-brown); font-style: italic; }
  .acad-terroir-stat span { color: var(--acad-muted); letter-spacing: 0.06em; text-transform: uppercase; font-size: 11px; }

  /* Responsive */
  @media (max-width: 1080px) {
    .acad-lesson-main { grid-template-columns: 1fr; }
    .acad-lesson-aside { position: static; }
    .acad-wine-grid { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 680px) {
    .acad-lesson-main { padding: 16px 20px 60px; }
    .acad-breadcrumb { padding: 16px 20px 0; }
    .acad-wine-grid { grid-template-columns: 1fr; }
    .acad-quiz-cta { flex-direction: column; align-items: flex-start; padding: 32px 24px; }
    .acad-acc-head { font-size: 19px; }
    .acad-acc-body-inner { padding-left: 0; }
  }
{% endstyle %}

<div class="academia">

  {%- comment -%} ===== BREADCRUMB ===== {%- endcomment -%}
  <div class="acad-breadcrumb">
    <a href="{{ section.settings.hub_url | default: '#' }}">Academia</a>
    <span class="acad-sep">/</span>
    <a href="{{ section.settings.hub_url | default: '#' }}">{{ section.settings.breadcrumb_month }}</a>
    <span class="acad-sep">/</span>
    <span class="acad-current">{{ section.settings.breadcrumb_lesson }}</span>
  </div>

  {%- comment -%} ===== MAIN LAYOUT ===== {%- endcomment -%}
  <div class="acad-lesson-main">
    <section>

      {%- comment -%} Hero {%- endcomment -%}
      <div class="acad-lesson-hero">
        <div class="acad-kicker">{{ section.settings.lesson_kicker }}</div>
        <h1>{{ section.settings.lesson_title }}</h1>
        <div class="acad-meta">
          <span class="acad-author">
            <span class="acad-mini-av">{{ section.settings.author_initial }}</span>
            {{ section.settings.author_name }}
          </span>
          <span><span class="acad-dot"></span>{{ section.settings.duration }}</span>
          <span><span class="acad-dot"></span>{{ section.settings.sections_label }}</span>
          <span><span class="acad-dot"></span>{{ section.settings.updated_label }}</span>
        </div>
      </div>

      {%- comment -%} Video {%- endcomment -%}
      <div class="acad-video-wrap">
        {% if section.settings.video_url != blank %}
          <video src="{{ section.settings.video_url }}" style="width:100%;height:100%;object-fit:cover;"></video>
        {% endif %}
        <div class="acad-video-inner">
          <div class="acad-video-top">
            <span>{{ section.settings.video_label_left }}</span>
            <span class="acad-lv">{{ section.settings.video_label_right }}</span>
          </div>
          <div class="acad-video-bottom">
            <div class="acad-video-title-overlay">{{ section.settings.video_quote }}</div>
            <div class="acad-video-controls">
              <span>HD</span><span>CC</span><span>1×</span>
            </div>
          </div>
        </div>
        <div class="acad-play-btn" title="Reproducir"></div>
      </div>

      {%- comment -%} Intro prose {%- endcomment -%}
      <div class="acad-section-eyebrow acad-left">{{ section.settings.intro_eyebrow }}</div>
      <h2 class="acad-section-title">{{ section.settings.intro_title }}</h2>
      <div class="acad-prose">
        {{ section.settings.intro_body }}
      </div>

      {%- comment -%} Accordion {%- endcomment -%}
      <div class="acad-section-eyebrow acad-left" style="margin-top:56px;">{{ section.settings.theory_eyebrow }}</div>
      <h2 class="acad-section-title">{{ section.settings.theory_title }}</h2>

      <div class="acad-accordion">
        {%- assign acc_index = 0 -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'accordion' -%}
            {%- assign acc_index = acc_index | plus: 1 -%}
            <div class="acad-acc-item{% if block.settings.open_default %} acad-open{% endif %}" {{ block.shopify_attributes }}>
              <button class="acad-acc-head">
                <span class="acad-acc-num">{{ acc_index | prepend: '00' | slice: -2, 2 }}</span>
                <span class="acad-acc-title">{{ block.settings.title }}</span>
                <span class="acad-acc-plus"></span>
              </button>
              <div class="acad-acc-body">
                <div class="acad-acc-body-inner">
                  {{ block.settings.body }}
                  {% if block.settings.pull_quote != blank %}
                    <div class="acad-pull">{{ block.settings.pull_quote }}</div>
                  {% endif %}
                </div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Wine cards {%- endcomment -%}
      <div class="acad-section-eyebrow">{{ section.settings.wines_eyebrow }}</div>
      <h2 class="acad-section-title">{{ section.settings.wines_title }}</h2>
      <div class="acad-wine-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'wine_card' -%}
            {% if block.settings.product != blank %}
              <a href="{{ block.settings.product.url }}" class="acad-wine-card" {{ block.shopify_attributes }}>
            {% else %}
              <div class="acad-wine-card" {{ block.shopify_attributes }}>
            {% endif %}
              <div class="acad-wine-img">
                {% if block.settings.product.featured_image != blank %}
                  <img src="{{ block.settings.product.featured_image | image_url: width: 400 }}" alt="{{ block.settings.wine_name }}" loading="lazy" style="width:60%;height:90%;object-fit:contain;">
                {% else %}
                  <svg viewBox="0 0 120 300" xmlns="http://www.w3.org/2000/svg">
                    <rect x="52" y="0" width="16" height="50" fill="{{ block.settings.bottle_color }}" opacity="0.7"/>
                    <path d="M42 56 Q42 66 36 86 L36 280 Q36 296 60 296 Q84 296 84 280 L84 86 Q78 66 78 56 Z" fill="{{ block.settings.bottle_color }}"/>
                    <rect x="38" y="140" width="44" height="88" fill="#FFFCF1"/>
                    <rect x="38" y="140" width="44" height="2" fill="{{ block.settings.bottle_color }}"/>
                    <rect x="38" y="226" width="44" height="2" fill="{{ block.settings.bottle_color }}"/>
                  </svg>
                {% endif %}
                {% if block.settings.vintage != blank %}
                  <div class="acad-vintage-stamp">{{ block.settings.vintage }}</div>
                {% endif %}
              </div>
              <div class="acad-wine-info">
                <div class="acad-wine-bodega">{{ block.settings.bodega }}</div>
                <div class="acad-wine-name">{{ block.settings.wine_name }}</div>
                <div class="acad-wine-meta">
                  <span class="acad-do">{{ block.settings.do_name }}</span>
                  <span>{{ block.settings.variety }}</span>
                </div>
              </div>
            {% if block.settings.product != blank %}
              </a>
            {% else %}
              </div>
            {% endif %}
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- comment -%} Quiz CTA {%- endcomment -%}
      <div class="acad-quiz-cta">
        <div>
          <div class="acad-kicker">{{ section.settings.quiz_kicker }}</div>
          <h3>{{ section.settings.quiz_title }}</h3>
          <p>{{ section.settings.quiz_description }}</p>
        </div>
        <a href="{{ section.settings.quiz_url | default: '#' }}" class="acad-quiz-btn">
          {{ section.settings.quiz_btn_text }}
          <span class="acad-arrow"></span>
        </a>
      </div>

    </section>

    {%- comment -%} ===== SIDEBAR ===== {%- endcomment -%}
    <aside class="acad-lesson-aside">
      <div class="acad-side-box">
        <div class="eyebrow">{{ section.settings.sidebar_month_label }}</div>
        <h3>{{ section.settings.sidebar_region_title }}</h3>
        <div class="acad-month-sub">{{ section.settings.sidebar_region_sub }}</div>

        <div class="acad-month-progress">
          <span>{{ section.settings.sidebar_progress_text }}</span>
          <div class="acad-bar"><i style="width:{{ section.settings.sidebar_progress_pct }}%;"></i></div>
          <span>{{ section.settings.sidebar_progress_pct }}%</span>
        </div>

        <ul class="acad-lesson-index">
          {%- for block in section.blocks -%}
            {%- if block.type == 'sidebar_lesson' -%}
              <li class="{% if block.settings.lesson_status == 'done' %}acad-done{% elsif block.settings.lesson_status == 'current' %}acad-current{% elsif block.settings.lesson_status == 'locked' %}acad-locked{% endif %}" {{ block.shopify_attributes }}>
                <div class="acad-num">
                  {% if block.settings.lesson_status == 'done' %}✓{% else %}{{ block.settings.num_label }}{% endif %}
                </div>
                <div class="acad-text">
                  <div class="acad-li-title">{{ block.settings.lesson_title }}</div>
                  <div class="acad-dur">{{ block.settings.lesson_duration }}</div>
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      </div>

      <div class="acad-side-box acad-terroir">
        <div class="eyebrow">Terruño</div>
        <h3 style="margin-bottom:14px;">Datos del <em>mes</em></h3>
        {%- for block in section.blocks -%}
          {%- if block.type == 'terroir_stat' -%}
            <div class="acad-terroir-stat" {{ block.shopify_attributes }}>
              <span>{{ block.settings.stat_label }}</span>
              <b>{{ block.settings.stat_value }}</b>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </aside>
  </div>

</div>

<script>
  // Accordion toggle
  document.querySelectorAll('.acad-acc-head').forEach(function(btn) {
    btn.addEventListener('click', function() {
      btn.closest('.acad-acc-item').classList.toggle('acad-open');
    });
  });
</script>

