{% unless template == 'index' %}
{% unless template contains 'page' and template contains 'password' %}
<div class="container">
  <nav class="breadcrumb row" role="navigation" aria-label="Migas de pan" style="font-size:12px;color:#888;padding:10px 0 6px;">
    <div class="col-12" itemscope itemtype="https://schema.org/BreadcrumbList" style="display:flex;flex-wrap:wrap;align-items:center;gap:4px;">
      <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
        <a href="{{ routes.root_url }}" itemprop="item" style="color:#888;text-decoration:none;">
          <span itemprop="name">Inicio</span>
        </a>
        <meta itemprop="position" content="1">
      </span>

      {% if template contains 'product' %}
        {% if collection.url %}
          <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="{{ collection.url }}" itemprop="item" style="color:#888;text-decoration:none;">
              <span itemprop="name">{{ collection.title }}</span>
            </a>
            <meta itemprop="position" content="2">
          </span>
          <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style="color:#555;font-weight:500;">
            <span itemprop="name">{{ product.title | truncatewords: 6 }}</span>
            <meta itemprop="item" content="{{ request.origin }}{{ product.url }}">
            <meta itemprop="position" content="3">
          </span>
        {% else %}
          <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="{{ routes.collections_url }}" itemprop="item" style="color:#888;text-decoration:none;">
              <span itemprop="name">Vinos</span>
            </a>
            <meta itemprop="position" content="2">
          </span>
          <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style="color:#555;font-weight:500;">
            <span itemprop="name">{{ product.title | truncatewords: 6 }}</span>
            <meta itemprop="item" content="{{ request.origin }}{{ product.url }}">
            <meta itemprop="position" content="3">
          </span>
        {% endif %}

      {% elsif template contains 'collection' and collection.handle %}
        <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
        {% if current_tags %}
          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            {% capture col_url %}/collections/{{ collection.handle }}{% endcapture %}
            <a href="{{ col_url }}" itemprop="item" style="color:#888;text-decoration:none;">
              <span itemprop="name">{{ collection.title }}</span>
            </a>
            <meta itemprop="position" content="2">
          </span>
          <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style="color:#555;font-weight:500;">
            <span itemprop="name">{{ current_tags | join: " + " }}</span>
            <meta itemprop="position" content="3">
          </span>
        {% else %}
          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style="color:#555;font-weight:500;">
            <span itemprop="name">{{ collection.title }}</span>
            <meta itemprop="item" content="{{ request.origin }}{{ collection.url }}">
            <meta itemprop="position" content="2">
          </span>
        {% endif %}

      {% elsif template == 'blog' %}
        <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
        {% if current_tags %}
          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="{{ blog.url }}" itemprop="item" style="color:#888;text-decoration:none;">
              <span itemprop="name">{{ blog.title }}</span>
            </a>
            <meta itemprop="position" content="2">
          </span>
          <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
          <span style="color:#555;font-weight:500;">{{ current_tags | join: " + " }}</span>
        {% else %}
          <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style="color:#555;font-weight:500;">
            <span itemprop="name">{{ blog.title }}</span>
            <meta itemprop="item" content="{{ request.origin }}{{ blog.url }}">
            <meta itemprop="position" content="2">
          </span>
        {% endif %}

      {% elsif template == 'article' %}
        <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
        <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
          <a href="{{ blog.url }}" itemprop="item" style="color:#888;text-decoration:none;">
            <span itemprop="name">{{ blog.title }}</span>
          </a>
          <meta itemprop="position" content="2">
        </span>
        <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
        <span itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem" style="color:#555;font-weight:500;">
          <span itemprop="name">{{ article.title | truncatewords: 6 }}</span>
          <meta itemprop="item" content="{{ request.origin }}{{ article.url }}">
          <meta itemprop="position" content="3">
        </span>

      {% elsif template contains 'search' %}
        <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
        <span style="color:#555;font-weight:500;">Buscar</span>

      {% elsif template contains 'cart' %}
        <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
        <span style="color:#555;font-weight:500;">Carrito</span>

      {% else %}
        <span aria-hidden="true" style="color:#ccc;font-size:10px;">&#8250;</span>
        <span style="color:#555;font-weight:500;">{{ page_title }}</span>
      {% endif %}
    </div>
  </nav>
</div>
{% endunless %}
{% endunless %}
