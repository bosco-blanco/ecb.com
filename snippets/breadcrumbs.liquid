{% unless template == 'index' %}
{% unless template contains 'page' %}
<div class="container">
	<nav class="breadcrumb row" role="navigation" aria-label="breadcrumbs">
		<div class="col-12">
			<a href="{{ routes.root_url }}" title="{{ 'wbcustomlabel.wballtext.home' | t }}">{{ 'wbcustomlabel.wballtext.home' | t }}</a>
			{% if template contains 'page' %}
				<span aria-hidden="true">{% render 'icon-arrow-right' %}</span>
				<span>{{ page.title }}</span>
			{% elsif template contains 'product' %}
			{% if collection.url %}
				<span aria-hidden="true">{% render 'icon-arrow-right' %}</span>
				{{ collection.title | link_to: collection.url }}
			{% endif %}
			<span aria-hidden="true">{% render 'icon-arrow-right' %}</span>
			<span>{{ product.title }}</span>
			{% elsif template contains 'collection' and collection.handle %}
				<span aria-hidden="true">{% render 'icon-arrow-right' %}</span>
			{% if current_tags %}
			{% capture url %}/collections/{{ collection.handle }}{% endcapture %}
				{{ collection.title | link_to: url }}
				<span aria-hidden="true">{% render 'icon-arrow-right' %}</span>
				<span>{{ current_tags | join: " + " }}</span>
			{% else %}
				<span>{{ collection.title }}</span>
			{% endif %}
			{% elsif template == 'blog' %}
				<span aria-hidden="true">{% render 'icon-arrow-right' %}</span>
			{% if current_tags %}
				{{ blog.title | link_to: blog.url }}
				<span aria-hidden="true">{% render 'icon-arrow-right' %}</span>
				<span>{{ current_tags | join: " + " }}</span>
			{% else %}
				<span>{{ blog.title }}</span>
			{% endif %}
			{% elsif template == 'article' %}
				<span aria-hidden="true">{% render 'icon-arrow-right' %}</span>
				{{ blog.title | link_to: blog.url }}
				<span aria-hidden="true">{% render 'icon-arrow-right' %}</span>
				<span>{{ article.title }}</span>
			{% else %}
				<span aria-hidden="true">{% render 'icon-arrow-right' %}</span>
				<span>{{ page_title }}</span>
			{% endif %}
		</div>
	</nav>
</div>

{%- liquid
  assign breadcrumb_items = ''
  assign position = 1
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": {{ 'wbcustomlabel.wballtext.home' | t | json }},
      "item": "{{ shop.url }}"
    }
    {%- if template contains 'product' -%}
      {%- if collection.url -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }},
        "item": "{{ shop.url }}{{ collection.url }}"
      }
      ,{
        "@type": "ListItem",
        "position": 3,
        "name": {{ product.title | json }}
      }
      {%- else -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ product.title | json }}
      }
      {%- endif -%}
    {%- elsif template contains 'collection' and collection.handle -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ collection.title | json }}
        {%- if current_tags -%}
          ,"item": "{{ shop.url }}/collections/{{ collection.handle }}"
        {%- endif -%}
      }
      {%- if current_tags -%}
      ,{
        "@type": "ListItem",
        "position": 3,
        "name": {{ current_tags | join: " + " | json }}
      }
      {%- endif -%}
    {%- elsif template == 'blog' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }}
        {%- if current_tags -%}
          ,"item": "{{ shop.url }}{{ blog.url }}"
        {%- endif -%}
      }
      {%- if current_tags -%}
      ,{
        "@type": "ListItem",
        "position": 3,
        "name": {{ current_tags | join: " + " | json }}
      }
      {%- endif -%}
    {%- elsif template == 'article' -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ blog.title | json }},
        "item": "{{ shop.url }}{{ blog.url }}"
      }
      ,{
        "@type": "ListItem",
        "position": 3,
        "name": {{ article.title | json }}
      }
    {%- else -%}
      ,{
        "@type": "ListItem",
        "position": 2,
        "name": {{ page_title | json }}
      }
    {%- endif -%}
  ]
}
</script>
{% endunless %}
{% endunless %}