{%- comment -%}
  Visual polish and contrast fixes for En Copa de Balon.
  Addresses: contrast WCAG AA, typography hierarchy, product cards,
  product page layout, announcement bar, buttons, and overall visual quality.
{%- endcomment -%}

{%- style -%}
  /* ============================================
     1. CONTRAST & COLOR FIXES (WCAG AA)
     ============================================ */
  :root {
    --ecdb-wine: #6b1d3a;
    --ecdb-wine-light: #8a2850;
    --ecdb-gold: #b8983a;
    --ecdb-gold-light: #d4b974;
    --ecdb-cream: #f7f4ed;
    --ecdb-dark: #1a1a1a;
    --ecdb-text: #2c2c2c;
    --ecdb-text-muted: #5a5a5a;
    --ecdb-border: #e0dbd0;
    --ecdb-green: #3d5a3c;
    --ecdb-green-dark: #2d4a2c;
    --ecdb-bg-warm: #faf8f4;
    --ecdb-shadow-sm: 0 1px 3px rgba(0,0,0,0.06);
    --ecdb-shadow-md: 0 4px 12px rgba(0,0,0,0.08);
    --ecdb-shadow-lg: 0 8px 30px rgba(0,0,0,0.10);
    --ecdb-transition: 0.25s cubic-bezier(0.4,0,0.2,1);
  }

  /* Fix olive green background contrast */
  .color-background-2 {
    color: #fff !important;
  }
  .color-background-2 a,
  .color-background-2 .price-item,
  .color-background-2 .card__heading a {
    color: #fff !important;
  }
  .color-background-2 .wbhomevendor {
    color: rgba(255,255,255,0.75) !important;
  }

  /* ============================================
     2. TYPOGRAPHY IMPROVEMENTS
     ============================================ */
  body {
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    text-rendering: optimizeLegibility;
  }

  h1, h2, h3, h4, h5, h6,
  .h0, .h1, .h2, .h3, .h4, .h5 {
    letter-spacing: -0.01em;
    text-wrap: balance;
  }

  /* Better price typography */
  .price-item--regular {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .price-item--sale {
    font-weight: 700;
    color: var(--ecdb-wine) !important;
    font-variant-numeric: tabular-nums;
  }
  .price-item--regular s {
    color: var(--ecdb-text-muted);
    font-weight: 400;
  }

  /* ============================================
     3. ANNOUNCEMENT BAR POLISH
     ============================================ */
  .announcement-bar {
    font-weight: 500;
    letter-spacing: 0.03em;
  }
  .announcement-bar a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* ============================================
     4. HEADER REFINEMENTS
     ============================================ */
  .header {
    border-bottom: 1px solid var(--ecdb-border);
  }
  .header__heading-logo-wrapper img {
    transition: opacity var(--ecdb-transition);
  }

  /* ============================================
     5. PRODUCT CARD VISUAL UPGRADE
     ============================================ */
  .card-wrapper.wbproduct-container {
    border-radius: 12px;
    overflow: hidden;
    transition: transform var(--ecdb-transition), box-shadow var(--ecdb-transition);
    background: #fff;
    border: 1px solid transparent;
  }
  .card-wrapper.wbproduct-container:hover {
    border-color: var(--ecdb-border);
    box-shadow: var(--ecdb-shadow-md);
  }

  /* Product card image area */
  .card__media {
    background: #fff;
    position: relative;
    overflow: hidden;
  }
  .card__media img {
    transition: transform 0.4s cubic-bezier(0.4,0,0.2,1);
  }
  .card-wrapper:hover .card__media img {
    transform: scale(1.04);
  }

  /* Card content area */
  .wbproductdes.card__content {
    padding: 12px 14px 16px;
  }
  .wbproductdes .product-title {
    font-size: 13px;
    font-weight: 500;
    line-height: 1.35;
    margin-bottom: 4px;
  }
  .wbproductdes .product-title a {
    color: var(--ecdb-text);
    text-decoration: none;
    transition: color var(--ecdb-transition);
  }
  .wbproductdes .product-title a:hover {
    color: var(--ecdb-wine);
  }

  /* Vendor name styling */
  .wbhomevendor {
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--ecdb-text-muted);
    font-weight: 500;
    margin-bottom: 2px;
  }

  /* Card badges */
  .wb_badge_pos .badge {
    font-size: 11px;
    font-weight: 600;
    padding: 4px 10px;
    border-radius: 4px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }
  .percent__badge-sale,
  .amount__badge-sale {
    background: var(--ecdb-wine) !important;
    color: #fff !important;
  }
  .soldout_product_badge {
    background: var(--ecdb-text-muted) !important;
    color: #fff !important;
  }
  .new_product_badge {
    background: var(--ecdb-gold) !important;
    color: #fff !important;
  }

  /* Add to cart button on cards */
  .wbproductdes .cartb,
  .wbproductdes .product-form__submit {
    background: var(--ecdb-green) !important;
    color: #fff !important;
    border: none !important;
    border-radius: 8px !important;
    font-size: 12px !important;
    font-weight: 600 !important;
    letter-spacing: 0.02em;
    padding: 10px 16px !important;
    min-height: 40px;
    transition: background var(--ecdb-transition), transform 0.1s ease !important;
  }
  .wbproductdes .cartb:hover,
  .wbproductdes .product-form__submit:hover {
    background: var(--ecdb-green-dark) !important;
  }
  .wbproductdes .cartb:active,
  .wbproductdes .product-form__submit:active {
    transform: scale(0.97) !important;
  }

  /* ============================================
     6. PRODUCT PAGE (PDP) IMPROVEMENTS
     ============================================ */
  /* Better price display on PDP */
  .product .price-item--regular {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--ecdb-text);
  }
  .product .price--on-sale .price-item--sale {
    font-size: 1.6rem;
    color: var(--ecdb-wine);
  }
  .product .price--on-sale .price-item--regular s {
    font-size: 1.1rem;
    color: var(--ecdb-text-muted);
    font-weight: 400;
  }

  /* PDP Add to Cart button */
  .product-form__submit {
    background: var(--ecdb-green) !important;
    color: #fff !important;
    border: none !important;
    border-radius: 10px !important;
    font-size: 16px !important;
    font-weight: 600 !important;
    padding: 16px 32px !important;
    min-height: 52px;
    letter-spacing: 0.02em;
    transition: all var(--ecdb-transition) !important;
    box-shadow: 0 2px 8px rgba(61,90,60,0.2);
  }
  .product-form__submit:hover {
    background: var(--ecdb-green-dark) !important;
    box-shadow: 0 4px 14px rgba(61,90,60,0.3);
    transform: translateY(-1px);
  }

  /* Product media gallery */
  .product__media-list {
    gap: 8px;
  }
  .product__media-item {
    border-radius: 8px;
    overflow: hidden;
    background: #fff;
    border: 1px solid var(--ecdb-border);
  }

  /* Product accordion tabs */
  .product__accordion .accordion__title {
    font-size: 14px;
    font-weight: 600;
    text-transform: none;
  }
  .product__accordion summary {
    padding: 14px 0;
    border-bottom: 1px solid var(--ecdb-border);
  }

  /* ============================================
     7. COLLECTION PAGE IMPROVEMENTS
     ============================================ */
  /* Better filter bar */
  .facets-container {
    padding: 12px 0;
    margin-bottom: 20px;
  }
  .facets__summary {
    background: var(--ecdb-bg-warm);
    border: 1px solid var(--ecdb-border);
    border-radius: 8px;
    padding: 10px 16px;
    font-weight: 500;
    transition: border-color var(--ecdb-transition);
  }
  .facets__summary:hover {
    border-color: var(--ecdb-gold-light);
  }

  /* Active filter chips */
  .active-facets__button {
    background: var(--ecdb-wine);
    color: #fff;
    border: none;
    border-radius: 20px;
    padding: 6px 12px;
    font-size: 12px;
    font-weight: 500;
  }

  /* Collection title */
  .collection-hero__title {
    font-size: 2rem;
    font-weight: 700;
  }

  /* ============================================
     8. BREADCRUMBS
     ============================================ */
  .breadcrumb {
    font-size: 12px;
    color: var(--ecdb-text-muted);
    padding: 12px 0;
  }
  .breadcrumb a {
    color: var(--ecdb-text-muted);
    text-decoration: none;
    transition: color var(--ecdb-transition);
  }
  .breadcrumb a:hover {
    color: var(--ecdb-wine);
  }

  /* ============================================
     9. FOOTER CLEANUP
     ============================================ */
  .footer {
    border-top: 2px solid var(--ecdb-border);
  }
  .footer a {
    transition: color var(--ecdb-transition);
  }
  .footer a:hover {
    color: var(--ecdb-gold) !important;
  }

  /* ============================================
     10. GLOBAL INTERACTION POLISH
     ============================================ */
  /* Smoother page transitions */
  @view-transition {
    navigation: auto;
  }

  /* Focus styles for accessibility */
  :focus-visible {
    outline: 2px solid var(--ecdb-gold);
    outline-offset: 2px;
    border-radius: 4px;
  }

  /* Better link underlines */
  .rte a {
    color: var(--ecdb-wine);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-thickness: 1px;
    transition: color var(--ecdb-transition);
  }
  .rte a:hover {
    color: var(--ecdb-wine-light);
  }

  /* Loading states */
  .loading-overlay {
    backdrop-filter: blur(2px);
  }

  /* Cart drawer improvements */
  .cart-drawer {
    border-left: 1px solid var(--ecdb-border);
    box-shadow: var(--ecdb-shadow-lg);
  }

  /* ============================================
     11. MOBILE-SPECIFIC VISUAL FIXES
     ============================================ */
  @media screen and (max-width: 749px) {
    /* Better mobile card grid */
    .product-grid .grid__item {
      padding: 0 4px;
    }

    /* Mobile product title */
    .product__title h1 {
      font-size: 1.3rem;
      line-height: 1.25;
      font-weight: 700;
    }

    /* Mobile price prominence */
    .product .price-item--regular {
      font-size: 1.4rem;
    }

    /* Mobile Add to Cart */
    .product-form__submit {
      font-size: 15px !important;
      padding: 14px 24px !important;
      min-height: 50px;
      width: 100%;
    }

    /* Mobile section spacing */
    .section-padding {
      padding-top: 24px;
      padding-bottom: 24px;
    }

    /* Fix horizontal overflow */
    body {
      overflow-x: hidden;
    }

    /* Mobile image banner text readability */
    .banner__content {
      background: rgba(0,0,0,0.35);
      backdrop-filter: blur(2px);
      padding: 20px;
      border-radius: 12px;
    }

    /* Mobile announcement bar */
    .announcement-bar {
      font-size: 11px;
      padding: 8px 12px;
    }

    /* Mobile header cleanup */
    .header {
      padding: 10px 16px;
    }

    /* Fix mobile card content bleeding */
    .wbproductdes.card__content {
      padding: 10px 10px 14px;
    }
    .wbproductdes .product-title {
      font-size: 12px;
      -webkit-line-clamp: 2;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  /* ============================================
     12. QUICK VIEW MODAL POLISH
     ============================================ */
  .wbquickview .mfp-content {
    border-radius: 16px;
    overflow: hidden;
    box-shadow: var(--ecdb-shadow-lg);
  }
  .wbquickview .mfp-close {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #fff;
    border-radius: 50%;
    box-shadow: var(--ecdb-shadow-sm);
    font-size: 20px;
    top: 8px;
    right: 8px;
  }
{%- endstyle -%}
