{%- comment -%}
  Indicador de urgencia/escasez de stock.
  Muestra "Ultimas X unidades" cuando el stock es bajo.

  Acepta:
  - product: {Object} Product Liquid object

  Configuracion:
  - threshold: numero de unidades por debajo del cual se muestra el aviso
  - Se usa inventory_quantity del variante seleccionado

  Uso:
  {% render 'stock-urgency', product: product %}
{%- endcomment -%}

{%- liquid
  assign urgency_threshold = 10
  assign variant = product.selected_or_first_available_variant
  assign qty = variant.inventory_quantity
  assign tracking = variant.inventory_management
-%}

{%- if tracking == 'shopify' and qty > 0 and qty <= urgency_threshold and variant.available -%}
  <div class="stock-urgency" style="margin:10px 0;padding:10px 14px;background:linear-gradient(135deg,#fef9e7,#fef3e2);border:1px solid #f5d89a;border-radius:8px;font-size:13px;color:#92400e;display:flex;align-items:center;gap:8px;">
    {%- if qty <= 3 -%}
      <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#e74c3c;animation:pulse-dot 1.5s infinite;flex-shrink:0;"></span>
      <span><strong>¡Últimas {{ qty }} unidades!</strong> — Esta botella se agota</span>
    {%- elsif qty <= 6 -%}
      <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#f39c12;flex-shrink:0;"></span>
      <span><strong>Quedan solo {{ qty }} unidades</strong> — Stock muy limitado</span>
    {%- else -%}
      <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:#f1c40f;flex-shrink:0;"></span>
      <span><strong>{{ qty }} unidades disponibles</strong> — Stock limitado</span>
    {%- endif -%}
  </div>
  <style>.stock-urgency{transition:all .3s}@keyframes pulse-dot{0%,100%{opacity:1}50%{opacity:.4}}</style>
{%- endif -%}
