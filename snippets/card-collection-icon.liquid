{% comment %}
  Renders a collection card

  Accepts:
  - card_collection: {Object} Collection Liquid object
  - media_aspect_ratio: {String} Size of the product image card. Values are "square" and "portrait". Default is "square" (optional)
  - columns: {Number}
  - extend_height: {Boolean} Card height extends to available container space. Default: false (optional)

  Usage:
  {% render 'card-collection' %}
{% endcomment %}

{%- liquid
  assign ratio = 1
  if card_collection.metafields.custom.icon and media_aspect_ratio == 'portrait'
    assign ratio = 0.8
  elsif card_collection.metafields.custom.icon and media_aspect_ratio == 'adapt'
    assign ratio = card_collection.metafields.custom.icon.aspect_ratio
  endif
  if ratio == 0 or ratio == null
    assign ratio = 1
  endif
-%}

{%- style -%}
  .custom_icon {
    padding: {{ media_padding }}px;
  }
  .ecdb_category_title {
    font-size: 1.25rem;
    color: var(--color-base-text);
    font-weight: "regular";
    text-align: "center";
    text-transform: uppercase;
    min-height: 50px;
  }
  .ecdb_category_link:hover {
    color: var(--color-base-text);
    .ecdb_category_title {
      text-decoration: underline;
      color: var(--color-base-text);
    }
  }
{%- endstyle -%}

<div class="card-wrapper animate-arrow cardhome_clg">
  <a href="{{ card_collection.url }}" role="link" class="ecdb_category_link">
    <div
      class="
        card
        card--{{ settings.card_style }}
        {% if card_collection.metafields.custom.icon %} card--media{% else %} card--text{% endif %}
        {% if settings.card_style == 'card' %} color-{{ settings.card_color_scheme }} gradient{% endif %}
        {% if extend_height %} card--extend-height{% endif %}
        {% if card_collection.metafields.custom.icon == nil and settings.card_style == 'card' %} ratio{% endif %}
      "
      style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
    >
      <div
        class="card__inner {% if settings.card_style == 'standard' %}color-{{ settings.card_color_scheme }} gradient{% endif %}{% if card_collection.metafields.custom.icon %} ratio{% endif %}"
        style="--ratio-percent: {{ 1 | divided_by: ratio | times: 100 }}%;"
      >
        {%- if card_collection.metafields.custom.icon -%}
          <div class="card__media">
            <div class="media media--transparent media--hover-effect">
              <img
                srcset="
                  {%- if card_collection.metafields.custom.icon.width >= 165 -%}{{ card_collection.metafields.custom.icon | image_url: width: 165 }} 165w,{%- endif -%}
                  {%- if card_collection.metafields.custom.icon.width >= 330 -%}{{ card_collection.metafields.custom.icon | image_url: width: 330 }} 330w,{%- endif -%}
                  {%- if card_collection.metafields.custom.icon.width >= 535 -%}{{ card_collection.metafields.custom.icon | image_url: width: 535 }} 535w,{%- endif -%}
                  {%- if card_collection.metafields.custom.icon.width >= 750 -%}{{ card_collection.metafields.custom.icon | image_url: width: 750 }} 750w,{%- endif -%}
                  {%- if card_collection.metafields.custom.icon.width >= 1000 -%}{{ card_collection.metafields.custom.icon | image_url: width: 1000 }} 1000w,{%- endif -%}
                  {%- if card_collection.metafields.custom.icon.width >= 1500 -%}{{ card_collection.metafields.custom.icon | image_url: width: 1500 }} 1500w,{%- endif -%}
                  {%- if card_collection.metafields.custom.icon.width >= 3000 -%}{{ card_collection.metafields.custom.icon | image_url: width: 3000 }} 3000w,{%- endif -%}
                  {{ card_collection.metafields.custom.icon | image_url }} {{ card_collection.metafields.custom.icon.width }}w
                "
                src="{{ card_collection.metafields.custom.icon | image_url: width: 1500 }}"
                sizes="
                  (min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: columns }}px,
                  (min-width: 768px) {% if columns > 1 %}calc((100vw - 10rem) / 2){% else %}calc(100vw - 10rem){% endif %},
                  calc(100vw - 3rem)
                "
                alt="{{ card_collection.title | escape }}"
                height="{{ card_collection.metafields.custom.icon.height }}"
                width="{{ card_collection.metafields.custom.icon.width }}"
                loading="lazy"
                class="motion-reduce lazyload custom_icon"
              >
            </div>
            {% if overlay_btn == true -%}
              <a href="{{ card_collection.url }}" class="discbtn button">
                {{- 'wbcustomlabel.wballtext.discover' | t -}}
              </a>
            {%- endif %}
          </div>
        {%- endif -%}

        {%- if card_collection == blank -%}
          {%- assign placeholder_image_index = forloop.index0 | modulo: 4 | plus: 1 -%}
          {%- assign placeholder_image = 'collection-apparel-' | append: placeholder_image_index -%}
          <div class="dummysvg card__media">{{ placeholder_image | placeholder_svg_tag: 'placeholder-svg' }}</div>
        {%- else -%}
          <div class="card__content {{ ct_alignment }}">
            {% comment %}
              <a
                {% if card_collection == blank %}
                  role="link" class="h3" aria-disabled="true"
                {% else %}
                  href="{{ card_collection.url }}" class="h3 {% if coll_upper == true %} uppercase{% endif %}"
                {% endif %}
              >
                {%- if card_collection.title != blank -%}
                  {{- card_collection.title | escape -}}
                {%- else -%}
                  {{ 'onboarding.collection_title' | t }}
                {%- endif -%}
              </a>
              {% if coll_des == true %}
                <p>{{ coll_desc }}</p>
              {% endif %}
            {% endcomment %}

            {%- if card_collection.title != blank -%}
              <p class="ecdb_category_title">{{- card_collection.title | escape -}}</p>
            {%- else -%}
              <p class="ecdb_category_title">{{ 'onboarding.collection_title' | t }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
      {% if card_collection != blank and settings.card_style == 'card' or card_collection.metafields.custom.icon %}
        <div class="card__content {{ ct_alignment }}">
          {% comment %}
            <a
              {% if card_collection == blank %}
                role="link" class="h3" aria-disabled="true"
              {% else %}
                href="{{ card_collection.url }}" class="h3 {% if coll_upper == true %} uppercase{% endif %}"
              {% endif %}
            >
              {%- if card_collection.title != blank -%}
                {{- card_collection.title | escape -}}
              {%- else -%}
                {{ 'onboarding.collection_title' | t }}
              {%- endif -%}
            </a>
            {% if coll_des == true %}
              <p>{{ coll_desc }}</p>
            {% endif %}
          {% endcomment %}
          {%- if card_collection.title != blank -%}
            <p class="ecdb_category_title">{{- card_collection.title | escape -}}</p>
          {%- else -%}
            <p class="ecdb_category_title">{{ 'onboarding.collection_title' | t }}</p>
          {%- endif -%}
        </div>
      {% endif %}
      {%- if card_collection == blank -%}
        <div class="card__content {{ ct_alignment }}">
          {% comment %}
            <a
              {% if card_collection == blank %}
                role="link" class="h3" aria-disabled="true"
              {% else %}
                href="{{ card_collection.url }}" class="h3 {% if coll_upper == true %} uppercase{% endif %}"
              {% endif %}
            >
              {%- if card_collection.title != blank -%}
                {{- card_collection.title | escape -}}
              {%- else -%}
                {{ 'onboarding.collection_title' | t }}
              {%- endif -%}
            </a>
            {% if coll_des == true %}
              <p>{{ coll_desc }}</p>
            {% endif %}
          {% endcomment %}
          {%- if card_collection.title != blank -%}
            <p class="ecdb_category_title">{{- card_collection.title | escape -}}</p>
          {%- else -%}
            <p class="ecdb_category_title">{{ 'onboarding.collection_title' | t }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </a>
</div>
