{%- comment -%}
  Trust badges para la pagina de producto.
  Se muestra junto/debajo del boton Add to Cart.

  Uso:
  {% render 'trust-badges' %}
{%- endcomment -%}

<div class="trust-badges" style="margin:16px 0;padding:12px 0;border-top:1px solid #eee;">
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
    <div style="display:flex;align-items:center;gap:6px;font-size:11px;color:#666;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3d5a3c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13" rx="2"/><path d="m16 8 4 2v6a2 2 0 0 1-2 2H6"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
      <span><strong>Envio seguro</strong><br>Embalaje reforzado</span>
    </div>
    <div style="display:flex;align-items:center;gap:6px;font-size:11px;color:#666;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3d5a3c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      <span><strong>Pago 100% seguro</strong><br>SSL encriptado</span>
    </div>
    <div style="display:flex;align-items:center;gap:6px;font-size:11px;color:#666;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3d5a3c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>
      <span><strong>Control de temperatura</strong><br>Cadena de frio</span>
    </div>
    <div style="display:flex;align-items:center;gap:6px;font-size:11px;color:#666;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#3d5a3c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"/></svg>
      <span><strong>+30 anos de experiencia</strong><br>Sumilleres expertos</span>
    </div>
  </div>
</div>
